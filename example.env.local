# Email dari Service Account (didapat dari Google Cloud Console)
GOOGLE_CLIENT_EMAIL="service-account@example.gserviceaccount.com"

# Private Key dari Service Account (Wajib menggunakan tanda kutip dan pastikan \n terbaca sebagai baris baru)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\YourKey\n-----END PRIVATE KEY-----\n"

# ID Spreadsheet (diambil dari URL browser)
SPREADSHEET_ID="your_spreadsheet_id"